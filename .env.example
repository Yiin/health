# Copy to .env and fill in real values (docker compose reads .env automatically).
# "postgres" is the local-dev default; use a strong password on the VPS.
POSTGRES_PASSWORD=postgres
POSTGRES_DB=health
# Host-side URL (next dev, drizzle-kit, scripts/migrate.mjs from the host).
# Compose overrides it for containers with the internal ...@db:5432 URL.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/health
# Host loopback port the db service is published on for host-side tooling.
DB_PORT=5433
# vitest DB tests (src/db/test-utils.ts) default to
# postgres://postgres:postgres@localhost:${DB_PORT}/health_test.
# Set this only if your local port or password differ.
#TEST_DATABASE_URL=
# Host loopback port the web service is published on.
# REQUIRED on the VPS: WEB_PORT=3100 — the meals app owns host 3000 there.
WEB_PORT=3000
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
# Host loopback port MinIO is published on (host-side tests only).
# REQUIRED on the VPS: MINIO_PORT=9080 — a ClickHouse container owns host 9000
# there; shipping the 9000 default makes docker compose up fail on the
# collision and takes web/worker down (incident 2026-07-18).
MINIO_PORT=9000
S3_ENDPOINT=http://minio:9000
S3_BUCKET=health
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
MOONSHOT_API_KEY=
KIMI_MODEL_CHAT=kimi-k2.6
# Per-file upload cap in bytes (default 2147483648 = 2 GiB; lower only for tests).
#UPLOAD_MAX_BYTES=
# Optional drive-by basic-auth gate (Tailscale is the real boundary; see README).
# Both must be set for the gate to activate; unset = open.
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

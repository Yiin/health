# Copy to .env and fill in real values (docker compose reads .env automatically).
POSTGRES_PASSWORD=
POSTGRES_DB=health
DATABASE_URL=postgres://postgres:CHANGEME@db:5432/health
# Host loopback port the web service is published on (3100 on the VPS; meals owns 3000).
WEB_PORT=3000
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
S3_ENDPOINT=http://minio:9000
S3_BUCKET=health
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
MOONSHOT_API_KEY=
KIMI_MODEL_CHAT=kimi-k2.6
